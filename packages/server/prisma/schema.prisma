generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campaign {
  id            String   @id @default(uuid())
  name          String
  description   String   @default("")
  coverImageUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pcs           Pc[]
  npcs          Npc[]
  monsters      Monster[]
  locations     Location[]
  mysteries     Mystery[]
  clues         Clue[]
  organizations Organization[]
  sessions      Session[]
  entityLinks   EntityLink[]

  @@map("campaigns")
}

/// playerId: soft reference to Player.id, no DB-level FK (same polymorphic-
/// reference tradeoff as EntityLink's fromId/toId) -- a deleted Player leaves
/// this dangling, resolved to "Unknown" at the UI layer rather than
/// cascading or being blocked.
model Pc {
  id                String   @id @default(uuid())
  campaignId        String
  playerId          String?
  name              String
  portraitImageUrl  String?
  roleOrClass       String   @default("")
  background        String   @default("")
  notes             String   @default("")
  inventory         String   @default("")
  level             Int      @default(1)
  xp                Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("pcs")
}

/// Root-level -- not scoped to a Campaign, since the same person can play
/// across multiple campaigns. See Campaign for the other root-level model.
model Player {
  id        String   @id @default(uuid())
  name      String
  phone     String   @default("")
  email     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("players")
}

model Npc {
  id               String   @id @default(uuid())
  campaignId       String
  name             String
  portraitImageUrl String?
  role             String   @default("")
  description      String   @default("")
  notes            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("npcs")
}

model Monster {
  id               String   @id @default(uuid())
  campaignId       String
  name             String
  portraitImageUrl String?
  description      String   @default("")
  behaviors        String   @default("")
  notes            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("monsters")
}

model Location {
  id               String   @id @default(uuid())
  campaignId       String
  parentLocationId String?
  name             String
  imageUrl         String?
  description      String   @default("")
  notes            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaign       Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parentLocation Location?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: SetNull)
  childLocations Location[] @relation("LocationHierarchy")

  @@map("locations")
}

/// status: "active" | "resolved" | "abandoned" (validated by the shared Zod schema, not the DB)
model Mystery {
  id          String   @id @default(uuid())
  campaignId  String
  name        String
  description String   @default("")
  status      String   @default("active")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  clues    Clue[]

  @@map("mysteries")
}

model Organization {
  id          String   @id @default(uuid())
  campaignId  String
  name        String
  imageUrl    String?
  description String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("organizations")
}

/// visibility: "hidden" | "revealed" (validated by the shared Zod schema, not the DB)
/// visibleTo: JSON-encoded array of PC ids, or null (not scoped — revealed to whole party)
model Clue {
  id         String   @id @default(uuid())
  campaignId String
  mysteryId  String?
  title      String
  content    String   @default("")
  gmNotes    String   @default("")
  visibility String   @default("hidden")
  visibleTo  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  mystery  Mystery? @relation(fields: [mysteryId], references: [id], onDelete: SetNull)

  @@map("clues")
}

/// status: "active" | "ended" (validated by the shared Zod schema, not the DB)
model Session {
  id                String    @id @default(uuid())
  campaignId        String
  title             String    @default("")
  status            String    @default("active")
  currentLocationId String?
  startedAt         DateTime  @default(now())
  endedAt           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  campaign Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  events   SessionEvent[]
  battles  BattleEncounter[]

  @@map("sessions")
}

/// type: SESSION_STARTED | SESSION_ENDED | LOCATION_CHANGED | GM_NOTE | BATTLE_STARTED |
/// BATTLE_ENDED | TURN_ADVANCED | DAMAGE_APPLIED | HEALING_APPLIED | STATUS_APPLIED |
/// STATUS_EXPIRED | KO (validated by the shared Zod schema, not the DB)
/// actorType/targetType: "pc" | "npc" | "monster" | null
model SessionEvent {
  id         String   @id @default(uuid())
  sessionId  String
  campaignId String
  type       String
  actorType  String?
  actorId    String?
  targetType String?
  targetId   String?
  payload    String   @default("{}")
  createdAt  DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_events")
}

/// status: "building" | "active" | "resolved" (validated by the shared Zod schema, not the DB)
model BattleEncounter {
  id               String   @id @default(uuid())
  sessionId        String
  campaignId       String
  status           String   @default("building")
  currentTurnIndex Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  entries InitiativeEntry[]

  @@map("battle_encounters")
}

/// actorType: "pc" | "npc" | "monster" | null (null when adHocName is set instead)
model InitiativeEntry {
  id                String   @id @default(uuid())
  battleEncounterId String
  actorType         String?
  actorId           String?
  adHocName         String?
  initiative        Int      @default(0)
  currentHp         Int?
  maxHp             Int?
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  battle   BattleEncounter         @relation(fields: [battleEncounterId], references: [id], onDelete: Cascade)
  statuses StatusEffectInstance[]

  @@map("initiative_entries")
}

model StatusEffectInstance {
  id                String   @id @default(uuid())
  initiativeEntryId String
  sourceEntryId     String?
  label             String
  note              String   @default("")
  appliedAtTurn     Int      @default(0)
  expired           Boolean  @default(false)
  createdAt         DateTime @default(now())

  entry InitiativeEntry @relation(fields: [initiativeEntryId], references: [id], onDelete: Cascade)

  @@map("status_effect_instances")
}

/// fromType/toType: EntityType (pcs|npcs|monsters|locations|mysteries|clues|organizations, validated by the
/// shared Zod schema, not the DB). No DB-level FK on the polymorphic type+id pair, same
/// tradeoff as InitiativeEntry/SessionEvent — a deleted entity's links degrade gracefully
/// (rendered as "Unknown") rather than being cascaded or blocked.
/// visibility: "hidden" | "revealed"
model EntityLink {
  id           String   @id @default(uuid())
  campaignId   String
  fromType     String
  fromId       String
  toType       String
  toId         String
  label        String
  reverseLabel String?
  directional  Boolean  @default(false)
  visibility   String   @default("revealed")
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("entity_links")
}

/// Global, not campaign-scoped -- the app has no multi-user concept yet, so
/// there is exactly one settings row (id fixed at "singleton"), read/created
/// via upsert so a row always exists without a separate seed step.
model Settings {
  id               String   @id @default("singleton")
  darkMode         Boolean  @default(false)
  primary          String   @default("#6750a4")
  surface          String   @default("#fffbfe")
  onSurface        String   @default("#1c1b1f")
  background       String   @default("#fffbfe")
  onBackground     String   @default("#1c1b1f")
  surfaceVariant   String   @default("#e7e0ec")
  onSurfaceVariant String   @default("#49454f")
  updatedAt        DateTime @updatedAt

  @@map("settings")
}
